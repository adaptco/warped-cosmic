# Agent Forge — Environment Variables
# Copy to .env and fill in all values before running locally.
# Add all values to GitHub Actions Secrets for CI/CD.

# ─── LLM APIs ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json  # Vertex AI

# ─── Webhooks ─────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# ─── Task Management ──────────────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...  # The DB where tasks are created
CLICKUP_API_KEY=pk_...
CLICKUP_LIST_ID=...

# ─── Airtable ─────────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...  # The base containing agent_mixture table

# ─── Zapier ───────────────────────────────────────────────────────────────────
ZAPIER_API_KEY=...
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/.../...

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=agent-forge-prod
FIREBASE_SERVICE_ACCOUNT=...  # JSON string of service account key

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...  # Auto-injected in Actions
GH_REPO=org/agent-forge

# ─── GCP / Vertex AI ──────────────────────────────────────────────────────────
GCP_PROJECT=agent-forge-gcp
GCP_REGION=us-central1

# ─── Echo Relay ───────────────────────────────────────────────────────────────
ECHO_RELAY_URL=http://localhost:8080  # or your deployed relay URL
ECHO_RELAY_SECRET=...  # HMAC secret for A2A envelope signing

# ─── Luma (Quality Gate) ──────────────────────────────────────────────────────
LUMA_SIGNING_KEY=...  # Ed25519 private key base64
