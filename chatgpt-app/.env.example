PORT=8787

# Canonical backend target (`app.mcp_gateway` /tools/call endpoint)
CHATGPT_APP_BACKEND_URL=http://127.0.0.1:8080/tools/call
CHATGPT_APP_BACKEND_BEARER=
CHATGPT_APP_TIMEOUT_MS=30000

# Submission metadata
CHATGPT_APP_DOMAIN=
CHATGPT_APP_RESOURCE_DOMAIN=
CHATGPT_APP_PRIVACY_URL=https://example.com/privacy
CHATGPT_APP_SUPPORT_URL=https://example.com/support

# GitHub OAuth configuration (user auth)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
GITHUB_OAUTH_AUTHORIZE_URL=https://github.com/login/oauth/authorize
GITHUB_OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_OAUTH_REQUIRED_SCOPES_READ=read:user
GITHUB_OAUTH_REQUIRED_SCOPES_WRITE=repo
